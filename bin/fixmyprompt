#!/usr/bin/env python3
"""FixMyPrompt CLI: fixmyprompt <try|report|status|on|off|mode|refine|selftest>"""
from __future__ import annotations

import json
import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from fixmyprompt import cc_tips, config, context_hints, daemon, outcome, refiner, report, scorer, suggest  # noqa: E402

_LAUNCH_AGENT = Path(os.path.expanduser("~")) / "Library" / "LaunchAgents" / "com.fixmyprompt.daemon.plist"


def cmd_report(args):
    days = int(args[0]) if args else 7
    print(report.summarize(days))
    print(outcome.summary(days=30))


def cmd_progress(args):
    period = args[0] if args and args[0] in ("day", "week", "month") else "week"
    print(report.progress(period))
    print(outcome.summary(days=30))


def cmd_suggest(args):
    if not args:
        print('usage: fixmyprompt suggest "your prompt"')
        return
    prompt = " ".join(args)
    feats = scorer.classify(prompt)
    s = scorer.suggest_model_effort(feats, prompt)
    print(f"mode: {feats['mode']}")
    print(f"→ {s['model']} · {s['effort']} effort")
    print(f"  {s['why']}")
    if s.get("note"):
        print(f"  ↑ {s['note']}")
    cc = cc_tips.analyze(prompt, feats)
    if cc:
        print(f"\n{cc['tip']}")


def cmd_tips(args):
    """Show the Claude Code feature tip a prompt would trigger (if any)."""
    if not args:
        print('usage: fixmyprompt tips "your prompt"')
        print("Surfaces a relevant Claude Code feature (/clear, /goal, plan mode, subagents)")
        return
    prompt = " ".join(args)
    cc = cc_tips.analyze(prompt, scorer.classify(prompt))
    print(cc["tip"] if cc else "No Claude Code feature tip for this prompt.")


_DIGEST_AGENT = Path(os.path.expanduser("~")) / "Library" / "LaunchAgents" / "com.fixmyprompt.digest.plist"
_NOTIFY = Path(os.path.expanduser("~")) / ".claude" / "memory" / "notify.sh"


def cmd_digest(args):
    """Send the weekly progress report to Telegram (or print if no notifier)."""
    import subprocess
    period = args[0] if args and args[0] in ("day", "week", "month") else "week"
    text = "📊 FixMyPrompt weekly progress\n\n" + report.progress(period)
    if _NOTIFY.exists():
        subprocess.run(["bash", str(_NOTIFY), text], capture_output=True)
        print("digest sent to Telegram.")
    else:
        print(text)
        print("\n(no notifier found at ~/.claude/memory/notify.sh — printed instead)")


def cmd_digest_schedule(args):
    """`fixmyprompt digest-schedule on|off` — Sunday 9am Telegram digest."""
    import subprocess
    on = args and args[0] == "on"
    if on:
        plist = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.fixmyprompt.digest</string>
  <key>ProgramArguments</key><array><string>{Path(__file__).resolve()}</string><string>digest</string><string>week</string></array>
  <key>StartCalendarInterval</key><dict><key>Weekday</key><integer>0</integer><key>Hour</key><integer>9</integer><key>Minute</key><integer>0</integer></dict>
</dict></plist>
"""
        _DIGEST_AGENT.parent.mkdir(parents=True, exist_ok=True)
        _DIGEST_AGENT.write_text(plist)
        uid = os.getuid()
        subprocess.run(["launchctl", "bootout", f"gui/{uid}/com.fixmyprompt.digest"], capture_output=True)
        subprocess.run(["launchctl", "bootstrap", f"gui/{uid}", str(_DIGEST_AGENT)], capture_output=True)
        print("FixMyPrompt: weekly Telegram digest scheduled for Sunday 9am.")
    else:
        subprocess.run(["launchctl", "bootout", f"gui/{os.getuid()}/com.fixmyprompt.digest"], capture_output=True)
        _DIGEST_AGENT.unlink(missing_ok=True)
        print("FixMyPrompt: weekly digest unscheduled.")


def cmd_tutorial(args):
    if not args or args[0] not in ("on", "off", "status"):
        cur = config.load().get("tutorial")
        print(f"tutorial mode: {'on' if cur else 'off'}   (fixmyprompt tutorial <on|off>)")
        print("  on = coach EVERY prompt (well-formed ones get an affirmation) so you")
        print("       learn what 'good' looks like, not just what's broken.")
        return
    if args[0] == "status":
        print(f"tutorial mode: {'on' if config.load().get('tutorial') else 'off'}")
        return
    config.save({"tutorial": args[0] == "on"})
    print(f"FixMyPrompt tutorial mode: {args[0].upper()} (applies to new sessions).")


def cmd_project(args):
    """Manage per-project clarifying hints (fixmyprompt project add/list/remove)."""
    sub = args[0] if args else "list"
    if sub == "list":
        hints = context_hints.list_project_hints()
        if not hints:
            print("No project hints yet. Add one with:")
            print('  fixmyprompt project add "<name-or-path-substring>" "<clarifying question>"')
            return
        for key, hint in hints.items():
            print(f"  {key!r:30} -> {hint}")
    elif sub == "add":
        if len(args) < 3:
            print('usage: fixmyprompt project add "<name-or-path-substring>" "<clarifying question>"')
            return
        key, hint = args[1], " ".join(args[2:])
        ok = context_hints.add_project_hint(key, hint)
        print(f"{'added' if ok else 'failed to add'}: {key!r} -> {hint!r}")
    elif sub in ("remove", "rm"):
        if len(args) < 2:
            print("usage: fixmyprompt project remove <name-or-path-substring>")
            return
        ok = context_hints.remove_project_hint(args[1])
        print("removed" if ok else f"no such hint: {args[1]!r}")
    else:
        print("usage: fixmyprompt project <list|add|remove>")


def cmd_status(_args):
    cfg = config.load()
    print("FixMyPrompt status")
    print(f"  mode         : {cfg['mode']}   (always | whisper | sigil | off)")
    print(f"  sigil        : {cfg['sigil']}")
    print(f"  min_words    : {cfg['min_words']}")
    print(f"  cooldown_sec : {cfg['cooldown_sec']}")
    print(f"  inject(tmux) : {cfg['inject']}")
    print(f"  model        : {cfg['model']}")
    print(f"  config       : {config.CONFIG_PATH}")
    print(f"  prompt log   : {config.RUNTIME_DIR / 'prompt-log.jsonl'}")


def cmd_on(_args):
    config.save({"mode": "always"})
    print("FixMyPrompt: live coaching ON (mode=always). Applies to new sessions.")


def cmd_off(_args):
    config.save({"mode": "off"})
    print("FixMyPrompt: live coaching OFF. /refine and the weekly report still work.")


def cmd_mode(args):
    if not args or args[0] not in ("always", "sigil", "whisper", "off"):
        print("usage: fixmyprompt mode <always|sigil|whisper|off>")
        print("  always  — block before send, show refined/scaffold")
        print("  whisper — no block; main model asks for the missing piece (subscription, no key)")
        print("  sigil   — only coach prompts starting with the sigil")
        print("  off     — disable live coaching")
        return
    config.save({"mode": args[0]})
    print(f"FixMyPrompt: mode={args[0]} (applies to new sessions).")


def cmd_refine(args):
    if not args:
        print('usage: fixmyprompt refine "your rough prompt"')
        return
    prompt = " ".join(args)
    feats = scorer.classify(prompt)
    r = refiner.refine(prompt)
    sug = scorer.suggest_model_effort(feats, prompt)
    # trust the LLM's mode only when it actually refined; else the local classifier
    # is the reliable source (the refiner returns a default "other" when it fails open).
    print(f"mode: {r.get('mode') if r.get('needs_refinement') else feats['mode']}"
          f"   ·   suggested: {sug['model']} · {sug['effort']} effort")

    if r.get("needs_refinement"):
        print("\n── refined ──")
        print(r["refined"])
        if r.get("tip"):
            print(f"\nwhy: {r['tip']}")
        return

    # LLM said no change (or the backend was unreachable and it failed open).
    # If the local classifier still sees real gaps, offer a deterministic scaffold
    # rather than a misleading "nothing to add".
    scaffold = suggest.template(prompt, feats)
    if scaffold:
        print("\n── scaffold (fill the <…> and send) ──")
        print(scaffold)
        print("\nwhy: naming the done-state turns an open-ended ask into a checkable "
              "one — you get one pass instead of a back-and-forth.")
        import os
        if not os.environ.get("ANTHROPIC_API_KEY"):
            print("\n(offline scaffold — set ANTHROPIC_API_KEY for a written LLM rewrite, "
                  "or use the /refine skill inside a session for a full one.)")
        return

    if feats["mode"] == "explore":
        print("\nThis is an explore prompt — intentionally open-ended. That's a valid "
              "discovery ask; no scaffolding needed. Tip: add 'as N distinct single "
              "screens' to keep the exploration cheap and comparable.")
    else:
        print("This prompt is already in good shape — nothing to add.")


def cmd_try(args):
    """Simulate the live Coach Gate on a prompt — shows exactly what teaching
    mode would do, without turning it on or touching your real log/state."""
    if not args:
        print('usage: fixmyprompt try "your rough prompt"')
        print("Shows what the live gate would do (block+coach, or pass silently).")
        return
    import shutil
    import subprocess
    import tempfile

    prompt = " ".join(args)
    feats = scorer.classify(prompt)
    cfg = dict(config.load())
    # preview using your configured mode if it's an intercepting one, else 'always'
    preview_mode = cfg["mode"] if cfg["mode"] in ("always", "sigil", "whisper") else "always"
    cfg["mode"] = preview_mode
    coach = scorer.should_coach(feats, cfg)

    print(f"mode: {feats['mode']}   preview as: {preview_mode}   would coach: {coach}")
    if feats.get("gaps"):
        print("gaps: " + ", ".join(feats["gaps"]))

    gate = Path(__file__).resolve().parent / "coach_gate.py"
    home = tempfile.mkdtemp()
    try:
        env = {
            **os.environ,
            "FIXMYPROMPT_HOME": home,          # sandbox: never touches your real log
            "PCOACH_MODE": preview_mode,
            "PCOACH_COOLDOWN": "0",
        }
        proc = subprocess.run(
            [sys.executable, str(gate)],
            input=json.dumps({"prompt": prompt, "session_id": "try"}),
            capture_output=True, text=True, env=env,
        )
        out = proc.stdout.strip()
        if not out:
            print("\n→ would PASS silently (not a coaching target).")
            if feats["is_continuation"]:
                print("  reason: a continuation/confirmation — never coached.")
            elif feats["is_command"]:
                print("  reason: a slash/bang/hash command — never coached.")
            elif feats["looks_like_paste"]:
                print("  reason: looks like pasted code/logs — never coached.")
            elif feats["mode"] != "execute":
                print(f"  reason: mode is '{feats['mode']}', not an under-specified build ask.")
            elif feats["word_count"] < cfg["min_words"]:
                print(f"  reason: only {feats['word_count']} words (under the {cfg['min_words']}-word gate).")
            else:
                print("  reason: already specified enough — nothing to add.")
            return
        # NOTE: the sandboxed run above can't see the real daemon (its socket
        # lives under the real FIXMYPROMPT_HOME), so a scaffold here may actually
        # be an AI rewrite live. Detect the real daemon and say so.
        real_daemon = daemon.is_running() and config.load().get("use_daemon")
        data = json.loads(out)
        if "decision" in data:
            if os.environ.get("ANTHROPIC_API_KEY"):
                key = "with a written AI rewrite"
            elif real_daemon:
                key = "with a written AI rewrite (your daemon is running)"
            else:
                key = "with a local scaffold (no API key)"
            print(f"\n→ would BLOCK and teach {key}:\n")
            print(data["reason"])
            if real_daemon and not os.environ.get("ANTHROPIC_API_KEY"):
                print("\n  (live, the running daemon would replace the scaffold above "
                      "with an AI-written rewrite you send with `y`.)")
        elif "hookSpecificOutput" in data:
            ctx = data["hookSpecificOutput"].get("additionalContext", "")
            print("\n→ WHISPER: would NOT block. Injects this note so your main model "
                  "(subscription, no key) asks for the missing piece:\n")
            print(ctx)
    finally:
        shutil.rmtree(home, ignore_errors=True)


def _agent_loaded() -> bool:
    import subprocess
    r = subprocess.run(["launchctl", "list", "com.fixmyprompt.daemon"], capture_output=True)
    return r.returncode == 0


def _bootout_agent():
    import subprocess
    subprocess.run(["launchctl", "bootout", f"gui/{os.getuid()}/com.fixmyprompt.daemon"],
                   capture_output=True)
    _LAUNCH_AGENT.unlink(missing_ok=True)


def _write_launch_agent():
    """KeepAlive LaunchAgent so the daemon survives crashes/reboots. Sets a full
    PATH (launchd's default is minimal) so the child can find `claude` wherever
    it's installed (homebrew / npm-global / ~/.local/bin)."""
    home = os.path.expanduser("~")
    path = (f"{home}/.local/bin:/opt/homebrew/bin:/usr/local/bin:"
            f"{home}/.npm-global/bin:{home}/.nvm/current/bin:/usr/bin:/bin")
    plist = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.fixmyprompt.daemon</string>
  <key>ProgramArguments</key>
  <array><string>{sys.executable}</string><string>-m</string><string>fixmyprompt.daemon</string><string>run</string></array>
  <key>EnvironmentVariables</key><dict>
    <key>PYTHONPATH</key><string>{Path(__file__).resolve().parent.parent}</string>
    <key>PATH</key><string>{path}</string>
  </dict>
  <key>KeepAlive</key><true/>
  <key>RunAtLoad</key><true/>
  <key>StandardErrorPath</key><string>{config.RUNTIME_DIR / 'daemon-launchd.log'}</string>
</dict></plist>
"""
    _LAUNCH_AGENT.parent.mkdir(parents=True, exist_ok=True)
    _LAUNCH_AGENT.write_text(plist)


def cmd_daemon(args):
    import subprocess
    sub = args[0] if args else "status"
    if sub == "status":
        s = daemon.status()
        print(f"daemon: {'running' if s['running'] else 'stopped'}"
              + (f" (pid {s['pid']}, {s.get('turns_served', 0)} turns served)" if s['running'] else ""))
        print(f"  socket: {s['socket']}")
        print(f"  keep-alive agent: {'installed' if _LAUNCH_AGENT.exists() else 'not installed'}")
    elif sub == "start":
        # manual, non-launchd start (for testing). If the KeepAlive agent owns
        # the daemon, don't fork a competing one.
        if _agent_loaded():
            print("daemon: managed by the KeepAlive agent (use `fixmyprompt daemon off` to stop).")
            return
        started = daemon.start()
        print("daemon: starting…" if started else "daemon: already running")
        if started:
            daemon.refine("warm up", timeout=8.0)  # prime the first refine (~1.7s)
    elif sub == "stop":
        # Unload the KeepAlive agent FIRST or launchd instantly respawns it.
        _bootout_agent()
        print("daemon: stopped" if daemon.stop() else "daemon: was not running")
    elif sub == "on":
        # The daemon only feeds the BLOCK gate (always/sigil); in whisper/off it
        # would sit idle. Switch to 'always' and remember the prior mode so
        # `daemon off` can restore it.
        cur = config.load()
        patch = {"use_daemon": True}
        switched = cur["mode"] in ("off", "whisper")
        if switched:
            patch["daemon_prior_mode"] = cur["mode"]
            patch["mode"] = "always"
        config.save(patch)
        _write_launch_agent()
        uid = os.getuid()
        # launchd exclusively owns the daemon (RunAtLoad starts it). Do NOT also
        # call daemon.start() — that created a competing owner + socket race.
        subprocess.run(["launchctl", "bootout", f"gui/{uid}/com.fixmyprompt.daemon"], capture_output=True)
        subprocess.run(["launchctl", "bootstrap", f"gui/{uid}", str(_LAUNCH_AGENT)], capture_output=True)
        import time as _t
        for _ in range(20):  # wait up to ~4s for launchd to bring the socket up, then warm it
            if daemon.is_running():
                break
            _t.sleep(0.2)
        daemon.refine("warm up", timeout=8.0)
        print("FixMyPrompt daemon: ON — fast AI-written rewrites on your subscription, no key.")
        if switched:
            print("Mode set to 'always' so the rewrites appear (whisper/off don't use the daemon).")
        print("The block gate will now show written rewrites (y to send). New sessions pick it up.")
    elif sub == "off":
        cur = config.load()
        patch = {"use_daemon": False}
        prior = cur.get("daemon_prior_mode")
        if prior and cur.get("mode") == "always":  # restore the mode `on` changed
            patch["mode"] = prior
        patch["daemon_prior_mode"] = None
        config.save(patch)
        _bootout_agent()          # stop launchd respawns first
        daemon.stop()             # then kill the process + clean its files
        restored = f" Mode restored to '{prior}'." if patch.get("mode") else ""
        print(f"FixMyPrompt daemon: OFF.{restored} Gate falls back to whisper/scaffold (still no key).")
    else:
        print("usage: fixmyprompt daemon <on|off|start|stop|status>")


def cmd_selftest(_args):
    """Fast smoke test with no network: classifier sanity on canonical inputs."""
    checks = [
        ("yes", "is_continuation", True),
        ("continue", "is_continuation", True),
        ("build me a dashboard", "mode", "execute"),
        ("blow me away with a landing page", "mode", "explore"),
        ("fix the login bug so that invalid passwords show an error", "has_done_criteria", True),
    ]
    ok = 0
    for prompt, key, expected in checks:
        got = scorer.classify(prompt)[key]
        flag = "ok" if got == expected else "FAIL"
        if got == expected:
            ok += 1
        print(f"  [{flag}] classify({prompt!r})[{key}] = {got!r} (want {expected!r})")
    print(f"{ok}/{len(checks)} classifier checks passed")
    sys.exit(0 if ok == len(checks) else 1)


COMMANDS = {
    "try": cmd_try,
    "daemon": cmd_daemon,
    "report": cmd_report,
    "progress": cmd_progress,
    "suggest": cmd_suggest,
    "tips": cmd_tips,
    "tutorial": cmd_tutorial,
    "project": cmd_project,
    "digest": cmd_digest,
    "digest-schedule": cmd_digest_schedule,
    "status": cmd_status,
    "on": cmd_on,
    "off": cmd_off,
    "mode": cmd_mode,
    "refine": cmd_refine,
    "selftest": cmd_selftest,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] not in COMMANDS:
        print("usage: fixmyprompt <try|suggest|progress|report|tutorial|mode|daemon|"
              "status|on|off|refine|selftest>")
        sys.exit(1)
    COMMANDS[sys.argv[1]](sys.argv[2:])


if __name__ == "__main__":
    main()
